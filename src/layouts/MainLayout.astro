---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  pathname: string;
  type?: 'website' | 'article';
  schema?: Record<string, any> | Record<string, any>[];
}

const { title, description, pathname, type = 'website', schema } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SeoHead title={title} description={description} pathname={pathname} type={type} schema={schema} />
  </head>
  <body class="bg-stone-50 text-stone-900 antialiased">
    <header class="border-b border-stone-200 bg-white/90 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-semibold tracking-tight text-stone-900">Kitchen Supplies 4 Less</a>
        <nav class="hidden gap-6 text-sm font-medium md:flex">
          {site.nav.map((item) => (
            <a href={item.href} class="text-stone-600 transition hover:text-orange-600">{item.label}</a>
          ))}
        </nav>
        <a
          href="https://www.kitchensupplies4less.com/"
          class="rounded-full bg-orange-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-orange-600"
        >
          Shop Now
        </a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-stone-200 bg-white">
      <div class="mx-auto grid max-w-6xl gap-8 px-6 py-10 md:grid-cols-[1.5fr_1fr_1fr]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-orange-600">Glendora kitchen gifts</p>
          <h2 class="mt-3 text-2xl font-semibold">Curated kitchenware with a warmer local feel.</h2>
          <p class="mt-3 max-w-xl text-sm leading-7 text-stone-600">
            This satellite site highlights giftable dinnerware, cookware, and kitchen finds from Kitchen Supplies 4 Less,
            an online-first business rooted in Glendora, California.
          </p>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-stone-900">Contact</h3>
          <ul class="mt-3 space-y-2 text-sm text-stone-600">
            <li>{site.business.name}</li>
            <li>{site.business.streetAddress}, {site.business.city}, {site.business.region} {site.business.postalCode}</li>
            <li><a href={`tel:${site.business.phone}`} class="hover:text-orange-600">{site.business.phone}</a></li>
            <li><a href={`mailto:${site.business.email}`} class="hover:text-orange-600">{site.business.email}</a></li>
            <li>{site.business.hours}</li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-stone-900">Explore</h3>
          <ul class="mt-3 space-y-2 text-sm text-stone-600">
            {site.nav.map((item) => (
              <li><a href={item.href} class="hover:text-orange-600">{item.label}</a></li>
            ))}
            <li><a href="https://www.kitchensupplies4less.com/" class="hover:text-orange-600">Main Store</a></li>
          </ul>
        </div>
      </div>
    </footer>
  </body>
</html>
