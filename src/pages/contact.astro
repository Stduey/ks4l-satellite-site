---
import MainLayout from '../layouts/MainLayout.astro';
import { site } from '../data/site';

const title = 'Contact Kitchen Supplies 4 Less | Glendora, CA';
const description = 'Contact Kitchen Supplies 4 Less for kitchen gifts, dinnerware, cookware, and product questions in Glendora, California.';
---
<MainLayout title={title} description={description} pathname="/contact">
  <section class="mx-auto max-w-5xl px-6 py-20">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-orange-600">Contact</p>
    <h1 class="mt-4 text-5xl font-semibold tracking-tight text-stone-900">Get in touch with Kitchen Supplies 4 Less.</h1>
    <div class="mt-10 grid gap-8 md:grid-cols-2">
      <div class="rounded-[2rem] border border-stone-200 bg-white p-8 shadow-sm">
        <h2 class="text-2xl font-semibold">Full business details</h2>
        <dl class="mt-6 space-y-4 text-sm leading-7 text-stone-700">
          <div>
            <dt class="font-semibold text-stone-900">Business name</dt>
            <dd>{site.business.name}</dd>
          </div>
          <div>
            <dt class="font-semibold text-stone-900">Location</dt>
            <dd>{site.business.city}, {site.business.region} {site.business.postalCode}</dd>
          </div>
          <div>
            <dt class="font-semibold text-stone-900">Phone</dt>
            <dd><a href={`tel:${site.business.phone}`} class="text-orange-600 hover:text-orange-700">{site.business.phone}</a></dd>
          </div>
          <div>
            <dt class="font-semibold text-stone-900">Email</dt>
            <dd><a href={`mailto:${site.business.email}`} class="text-orange-600 hover:text-orange-700">{site.business.email}</a></dd>
          </div>
          <div>
            <dt class="font-semibold text-stone-900">Hours</dt>
            <dd>{site.business.hours}</dd>
          </div>
        </dl>
      </div>
      <div class="rounded-[2rem] bg-orange-50 p-8">
        <h2 class="text-2xl font-semibold">What this site is for</h2>
        <p class="mt-4 text-sm leading-7 text-stone-700">
          This focused site helps shoppers discover featured kitchen gifts and cookware, then directs them to the main store
          for checkout and full catalog browsing.
        </p>
        <div class="mt-6 flex flex-wrap gap-4">
          <a href="https://www.kitchensupplies4less.com/" class="rounded-full bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">Visit main store</a>
          <a href="mailto:hello@kitchensupplies4less.com" class="rounded-full border border-orange-300 px-5 py-3 text-sm font-semibold text-orange-700 hover:border-orange-500">Send email</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
