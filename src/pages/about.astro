---
import MainLayout from '../layouts/MainLayout.astro';

const title = 'About Kitchen Supplies 4 Less | Glendora kitchen curation';
const description = 'Learn the story behind Kitchen Supplies 4 Less, a Glendora-rooted kitchen gift and cookware brand built around thoughtful curation.';
---
<MainLayout title={title} description={description} pathname="/about">
  <section class="mx-auto max-w-5xl px-6 py-20">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-orange-600">About Kathy</p>
    <h1 class="mt-4 text-5xl font-semibold tracking-tight text-stone-900">Kitchen supplies with a community story behind them.</h1>
    <div class="mt-8 grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="space-y-6 text-lg leading-8 text-stone-700">
        <p>
          Kitchen Supplies 4 Less is shaped around Kathy's eye for kitchen finds that feel useful, giftable, and welcoming.
          Her Glendora roots and community involvement give the brand a warmer identity than a generic catalog store.
        </p>
        <p>
          The site focuses on pieces that can anchor a table, elevate a kitchen gift, or help someone enjoy cooking at home,
          especially elegant dinnerware, enamel cookware, and practical hostess-ready finds.
        </p>
        <p>
          The result is a local-first presentation for an online store: easy to browse, grounded in trust, and designed to send
          shoppers straight to the main Kitchen Supplies 4 Less storefront when they are ready to buy.
        </p>
      </div>
      <aside class="rounded-[2rem] border border-stone-200 bg-white p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-stone-500">Highlights</p>
        <ul class="mt-5 space-y-4 text-sm leading-7 text-stone-700">
          <li><strong>Location:</strong> Glendora, California</li>
          <li><strong>Focus:</strong> Kitchen gifts, dinnerware, cookware, and curated home entertaining finds</li>
          <li><strong>Shopping model:</strong> Browse here, then shop the main store at kitchensupplies4less.com</li>
          <li><strong>Audience:</strong> Gift buyers, home cooks, housewarming shoppers, and local supporters across Southern California</li>
        </ul>
      </aside>
    </div>
  </section>
</MainLayout>
